<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0D0D1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:minHeight="600dp">

        <!-- Top spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Circular icon container with gradient ring -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp">

            <!-- Outer ring -->
            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@android:color/transparent" />

            <!-- Inner circle with icon -->
            <LinearLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:background="@android:color/transparent">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    android:tint="#FF6C7BFF"
                    android:contentDescription="Alarm icon" />
            </LinearLayout>
        </FrameLayout>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MEDICINE REMINDER"
            android:textColor="#FF6C7BFF"
            android:textSize="12sp"
            android:letterSpacing="0.3"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <!-- Medicine Name -->
        <TextView
            android:id="@+id/medicine_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medicine"
            android:textColor="#FFFFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- Divider -->
        <View
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:background="#FF6C7BFF"
            android:layout_marginBottom="28dp" />

        <!-- Details card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF161625"
            android:padding="20dp"
            android:layout_marginBottom="48dp">

            <!-- Dosage row -->
            <LinearLayout
                android:id="@+id/dosage_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:tint="#FF9CA3AF"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Dosage" />

                <TextView
                    android:id="@+id/dosage_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500 mg"
                    android:textColor="#FFDFE1E6"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Food instruction row -->
            <LinearLayout
                android:id="@+id/food_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    android:tint="#FF9CA3AF"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Food" />

                <TextView
                    android:id="@+id/food_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Take after food"
                    android:textColor="#FFDFE1E6"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    android:tint="#FF9CA3AF"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Time" />

                <TextView
                    android:id="@+id/time_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="19:00"
                    android:textColor="#FFDFE1E6"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Take Now Button -->
        <Button
            android:id="@+id/take_button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="TAKE NOW"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:backgroundTint="#FF6C7BFF"
            android:layout_marginBottom="12dp"
            android:fontFamily="sans-serif-medium" />

        <!-- Dismiss Button -->
        <Button
            android:id="@+id/dismiss_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Dismiss"
            android:textSize="14sp"
            android:textColor="#FF8888AA"
            android:backgroundTint="#FF1A1A2E"
            android:fontFamily="sans-serif" />

    </LinearLayout>
</ScrollView>
